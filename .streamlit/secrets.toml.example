# Deploy no Streamlit Cloud — copie para secrets.toml e preencha.
SPREADSHEET_ID = ""
EVENTOS_TAB = "eventos_manychat"

# Senha do dashboard (gate de acesso). Deixe vazio para liberar sem senha.
app_password = ""

[gcp_service_account]
type = "service_account"
project_id = ""
private_key_id = ""
private_key = ""
client_email = ""
client_id = ""
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = ""
universe_domain = "googleapis.com"
